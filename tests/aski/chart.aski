(Chart Element Sign)

Element (Fire Earth Air Water)

Sign (Aries Taurus Gemini Cancer Leo Virgo
      Libra Scorpio Sagittarius Capricorn Aquarius Pisces)

classify ([element(:@Self) Element])

classify [Sign [
  element(:@Self) Element (|
    (Aries)       Fire
    (Taurus)      Earth
    (Gemini)      Air
    (Cancer)      Water
    (Leo)         Fire
    (Virgo)       Earth
    (Libra)       Air
    (Scorpio)     Water
    (Sagittarius) Fire
    (Capricorn)   Earth
    (Aquarius)    Air
    (Pisces)      Water
  |)
]]
