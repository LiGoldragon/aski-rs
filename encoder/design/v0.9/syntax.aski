;; Aski v0.9 — complete syntax specification
;;
;; Supersedes v0.8. This is the authoritative spec.
;; v0.9: all Rust gaps bridged — zero new symbols, zero new delimiters.
;;
;; DESIGN PRINCIPLES:
;;   Highest signal-to-noise ratio for both humans and LLMs.
;;   No keywords — every symbol carries meaning.
;;   If it exists, it has a name. No anonymous variables, generics, or lifetimes.
;;   Move by default (actor model). Borrow is the explicit exception.
;;   Async by default. Core is the language, not a library.
;;   Every binding creates a named sub-type (newtype pattern via rkyv).
;;   Allocated names are owned — no re-allocation in the same scope.
;;   Inspired by Shen: pattern matching as primary definition, extensible power.
;;   No free functions — all behavior belongs to types. Main is the only entry point.
;;   Names ARE meaning — every binding name is a sub-type. No abbreviations.
;;   @Radius.new(Value(5.0)) — name matches type, no redundancy.
;;   @CircleRadius Radius.new(Value(5.0)) — different name creates sub-type.
;;   Everything is a domain. A Domain defines the structure of the domains
;;   it contains. Enumerators create branches. Structs create leaves.
;;   (A leaf can contain branches — the tree metaphor doesn't map to a
;;   real-world tree, but the recursion is natural.)
;;   World is the top-level Domain that contains all domains.
;;   Every domain is a variant of World. If a variant name matches an
;;   existing domain, that domain IS the variant's data.
;;   Binary: first byte = World variant ordinal, then the domain's own data.


;; =============================================================
;; 1. SEVEN DELIMITERS
;; =============================================================
;;
;; Glyph   Planet    Quality      Usage
;; ()      Sol       Identity     Domain variants, struct construction (auto-Protocol),
;;                                singleton calls, trait envelope, commit arms,
;;                                file header: module identity + exports
;; []      Luna      Reflection   ALL bodies (function, method),
;;                                inline eval, collection construction,
;;                                backtrack arms, file header: imports
;; {}      Saturn    Structure    Struct declaration, generic params+bounds,
;;                                const values, mutation on types, destructure arms,
;;                                file header: compilation constraints
;; (||)    Match     Dispatch     Pattern matching, matching function bodies,
;;                                three arm types: () commit, [] backtrack, {} destructure
;; [||]    FREE      (available)  Was comprehension — now freed
;; {||}    FREE      (available)  Reserved
;; <>      FREE      (available)  Reserved


;; =============================================================
;; 2. SYMBOLS
;; =============================================================
;;
;; Symbol  Name               Meaning
;; @       Instance           Allocated value — on allocation and ALL references (not on traits)
;; :       Immutable borrow   Viewing without owning
;; ~       Mutable borrow     Exclusive access, can mutate
;; &       Trait combination   display&classify creates compound type
;; .       Access             Field, method, namespace, .new() construction
;; $       Interpolation      Sugar for [@X.to_string] inside strings
;; ^       Return             Mandatory return prefix
;; #       Yield              Partial return (generators)
;; >       Greater-than       Comparison operator only
;; '       Lifetime/scope     Named lifetime prefix
;; ?       Error propagation  Postfix — propagates Err
;; !       Const              Compile-time fixity prefix
;; |       Separator          Or-pattern, sequence destructure
;; ==      Equals sugar       Sugar for .equals
;; ..      Exclusive range    start..end
;; ..=     Inclusive range     start..=end
;; ...     Variadic           Protocol input shapes — zero or more
;; ;;      Comment            Line comment
;; ___     Stub               Placeholder for unwritten body


;; =============================================================
;; 3. NAMED DELIMITERS
;; =============================================================
;;
;; Symbol directly before delimiter, NO space:
;;
;;   Name(...)   Solar Protocol call / struct construction
;;   Name[...]   Lunar Protocol call
;;   Name{...}   Saturn: generic params / Protocol call
;;   Name<...>   (available — reserved)
;;
;; SPACE SIGNIFICANCE:
;;
;;   Name (...)   WITH space = domain declaration (solar identity)
;;   Name(...)    NO space   = Protocol call / construction


;; =============================================================
;; 4. CASING
;; =============================================================
;;
;; PascalCase = nouns — domains, sub-types, struct fields, variants
;; camelCase  = verbs — traits, methods
;;
;; A trait is a verb (behavior). A domain is a noun (identity).
;; No free functions — every verb belongs to a noun.
;; Free functions are half-implemented traits.


;; =============================================================
;; 5. CORE TYPES (always available)
;; =============================================================

;; Pair{element} { First element Second element }
;; Triple{element} { First element Second element Third element }
;; Option{element} (Some(element) None)
;; Result{value error} (Ok(value) Err(error))
;; Vec{element} — growable collection
;; Map{key value} — key-value collection
;; Iterator{element} — lazy sequence


;; =============================================================
;; 6. CORE SINGLETONS (always exist, no @, no construction)
;; =============================================================
;;
;; StdOut   — output (solar Protocol for printing)
;; StdErr   — error output
;; StdIn    — input
;; Env      — environment variables
;; Args     — command line arguments


;; =============================================================
;; 7. DOMAINS — everything is a domain
;; =============================================================
;;
;; A Domain defines the structure of the domains it contains.
;; Enumerators (solar parens) create branches — choices between sub-domains.
;; Structs (saturnian braces) create leaves — composite values with named fields.
;; A leaf can contain branches: the tree is recursive, not a real-world tree.
;;
;; World is the top-level Domain. Every domain declaration creates a variant
;; of World. If a variant name matches an existing domain, that domain IS
;; the data carried by the variant. No linking syntax needed — the name is
;; the link.
;;
;; Variant forms:
;;   Variant              Unit — no data (leaf of the branch)
;;   Variant (Type)       Solar wrap — carries a single value
;;   Variant { fields }   Struct — named fields (inline leaf)
;;   Variant (A B C)      Inline enum — sub-branches
;;
;; If a variant name matches a domain defined elsewhere, that domain
;; IS the variant's data. Separate definition, automatic linking.

;; Enum-domains
Element (Fire Earth Air Water)
Modality (Cardinal Fixed Mutable)
Sign (Aries Taurus Gemini Cancer Leo Virgo
      Libra Scorpio Sagittarius Capricorn Aquarius Pisces)

;; Struct-domains
Point { Horizontal F64 Vertical F64 }
NatalChart { SunSign Sign MoonSign Sign Rising Sign }

;; Data-carrying variants — space before delimiter = declaration
Shape (
  Circle (F64)
  Rectangle { Width F64 Height F64 }
  Triangle { Base F64 Height F64 }
)

;; Generic data-carrying (how Option/Result are defined)
;; Option{T} (Some (T) None)
;; Result{T E} (Ok (T) Err (E))

;; Recursive types — compiler auto-boxes where needed (no Box in source)
Expr (
  Literal (F64)
  BinOp { Left Expr Op Operator Right Expr }
  Unary { Op Operator Inner Expr }
)

;; Nested domain inside struct-domain
User {
  Name (Arthur Dorothee Adam)
  Access { Level (Minimum Medium Maximum)
           Branches (Main Development Research) }
}


;; =============================================================
;; 8. STRUCT-DOMAIN CONSTRUCTION (auto-Protocol)
;; =============================================================
;;
;; Every struct declaration auto-generates a solar () Protocol.
;; Sub-types are named — order-independent.

Point(Horizontal(1.0) Vertical(2.0))
Point(Vertical(2.0) Horizontal(1.0))           ;; same thing — names resolve

NatalChart(SunSign(Aries) MoonSign(Cancer) Rising(Libra))

User(Name(Arthur) Access(Level(Maximum) Branches(Research)))


;; =============================================================
;; 9. CONSTANTS
;; =============================================================
;;
;; ! prefix = compile-time fixity. {} holds the value.

!MaxSigns U32 {12}
!MaxDecans U32 {36}
!Pi F64 {3.14159265358979}
!DegreesPerSign F64 {30.0}

;; Const method
U32 [ !degreesInSigns(:@Self) F64 [ ^(@Self.to_f64 * !DegreesPerSign) ] ]

;; Const generic
!Array{N T} { ___ }

;; Const in struct context
Placement {
  !MaxPlanets U32 {10}
  Body Sign
  Degree F64
}


;; =============================================================
;; 10. BINDINGS — named sub-types
;; =============================================================
;;
;; Every binding creates a named sub-type. Allocated names are owned
;; and cannot be re-allocated in the same scope.
;;
;; Three forms:
;;
;; SAME-TYPE (most common — name matches an existing type):
;;   @Radius.new(Value(5.0))
;;   Parser sees @Radius, checks Radius exists as a type, .new() constructs it.
;;
;; SUB-TYPE (name differs from base type — creates a new wrapping sub-type):
;;   @CircleRadius Radius.new(Value(5.0))
;;   Creates sub-type CircleRadius wrapping Radius.
;;
;; TWO-STEP (when value comes later):
;;   CircleRadius Radius      ;; declare sub-type slot
;;   @CircleRadius.new(expr)  ;; allocate later
;;
;; After allocation, @Name references the instance everywhere.
;; Name after @ must NOT already exist as a type (parser error if collision)
;; unless it matches the base type exactly (same-type form).
;;
;; NAMES ARE MEANING: Every binding name must be descriptive.
;; @Radius not @R. @Distance not @D. The name IS the type.
;;
;; .new() KNOWS THE TYPE: Don't repeat the type name inside the args:
;;   @Radius.new(Value(5.0))                ;; correct — fields only
;;   @Radius.new(Radius(Value(5.0)))         ;; wrong — redundant wrapper
;;
;; MUTABLE BINDINGS: ~@ declares a mutable binding. Can be updated
;; with ~@Name.set(value). Immutable @Name.new() cannot be re-allocated.
;;   @Radius.new(Value(5.0))                ;; immutable — committed
;;   ~@Counter U32.new(0)                   ;; mutable — can be updated
;;   ~@Counter.set([@Counter + 1])          ;; update mutable binding

Radius { Value F64 }

Radius [
  area(:@Self) F64 [
    @Area F64.new([@Self.Value * @Self.Value * !Pi])
    ^@Area
  ]
]

;; Two-step when value comes later
ChartInput { Raw String }

ChartInput [
  process(:@Self) String [
    Result String              ;; declare sub-type slot — value not yet known
    ;; ... compute things ...
    @Result.new("done")        ;; allocate when ready
    ^@Result
  ]
]

;; Same-type binding — most common
;; @Radius.new(Value(5.0))          ;; Radius type exists, instance created
;; @Area F64.new([@X * @Y])         ;; Area sub-type wrapping F64


;; =============================================================
;; 11. SCOPING RULES AND INVALID PATTERNS
;; =============================================================
;;
;; Types can be defined at two scopes:
;;   MODULE SCOPE — top-level in a file (file = module)
;;   BODY SCOPE — inside a method body []
;;
;; Body-scoped types are local to that method. They CANNOT appear in:
;;   - Return types
;;   - Parameter types
;;   - Any position visible outside the method
;;
;; This is enforced by CozoDB query: any type with a non-null parent
;; node that appears in a returns relation is a compile error.

;; VALID — body-scoped type used only internally
Point [
  distance(:@Self @Other Point) F64 [
    ;; DistSquared is body-scoped — only used locally
    DistSquared { Dx F64 Dy F64 }
    @DistSquared.new(
      Dx([(@Self.Horizontal - @Other.Horizontal) * (@Self.Horizontal - @Other.Horizontal)])
      Dy([(@Self.Vertical - @Other.Vertical) * (@Self.Vertical - @Other.Vertical)])
    )
    ^[@DistSquared.Dx + @DistSquared.Dy].sqrt
  ]
]

;; INVALID — body-scoped type in return position
;; Point [
;;   broken(:@Self) DistSquared [        ;; ERROR: DistSquared not visible here
;;     DistSquared { Dx F64 Dy F64 }
;;     @DistSquared.new(Dx(1.0) Dy(2.0))
;;     ^@DistSquared
;;   ]
;; ]
;; Compiler error: "type DistSquared is body-scoped and cannot be returned"

;; INVALID — re-allocation of immutable binding
;; Point [
;;   broken(:@Self) F64 [
;;     @Area F64.new(1.0)
;;     @Area.new(2.0)                    ;; ERROR: @Area already allocated
;;   ]
;; ]
;; Compiler error: "name Area is already allocated in this scope"
;; Use ~@Area for mutable bindings: ~@Area U32.new(1), ~@Area.set(2)

;; INVALID — name collision with existing type
;; Point [
;;   broken(:@Self) F64 [
;;     @Point F64.new(1.0)               ;; ERROR: Point already exists as a type
;;   ]
;; ]
;; Compiler error: "type Point already exists — cannot create sub-type with same name"
;; Exception: same-type binding @Point.new(...) is valid when constructing a Point

;; INVALID — free function at module scope
;; add(@Addition) U32 [ ... ]            ;; ERROR: no free functions
;; All behavior must be on a type: Addition [ add(:@Self) U32 [ ... ] ]

;; INVALID — returning a type that doesn't exist
;; Point [
;;   broken(:@Self) Nonexistent [ ... ]  ;; ERROR: Nonexistent is not a known type
;; ]

;; INVALID — abbreviation names
;; @R Radius.new(...)                    ;; ERROR: single-letter names prohibited
;; @Dist F64.new(...)                    ;; ERROR: use @Distance
;; Names ARE meaning — every binding name is a sub-type


;; =============================================================
;; 12. NO FREE FUNCTIONS — all behavior on types
;; =============================================================
;;
;; Every method belongs to a type via inherent impl or trait impl.
;; No free functions exist. Main is the only entry point.
;;
;; The delimiter after the return type determines the method form:
;;
;; name(params) Type [body]    Computed method — Luna
;; name(params) Type (| ... |) Matching method — Match
;;
;; Computed: steps, state, explicit ^return.
;; Matching: pattern dispatch, each arm is implicitly a return.

Addition { Left U32 Right U32 }

;; Computed method — lunar body
Addition [
  add(:@Self) U32 [
    ^(@Self.Left + @Self.Right)
  ]
]

;; Matching method — match body
Element [
  describe(:@Self) String (|
    (Fire)  "passionate"
    (Earth) "grounded"
    (Air)   "intellectual"
    (Water) "intuitive"
  |)
]


;; =============================================================
;; 13. MATCHING METHODS — pattern dispatch
;; =============================================================
;;
;; Parameters declare what's being matched.
;; Each arm: (pattern) result
;; No ^ needed — each arm is a return.

;; Single input match
Element [
  isFire(:@Self) Bool (|
    (Fire) True
    (_)    False
  |)

  ;; Or-pattern with |
  category(:@Self) String (|
    (Fire | Air)    "active"
    (Earth | Water) "receptive"
  |)
]

;; Multi-value match — method on Element with Modality param
;; Both params are domains so patterns dispatch directly on variants
Element [
  classify(:@Self @Modality) String (|
    (Fire Cardinal) "initiator"
    (Fire _)        "burns steady"
    (Water Fixed)   "deep"
    (Water _)       "flows"
    (Earth _)       "builds"
    (Air _)         "thinks"
  |)
]

;; Arm with computation — [] body when an arm needs work
NatalChart [
  describePlacement(:@Self) String (|
    (Fire Cardinal) [
      @Intensity F64.new([@Self.SunSign.degree / 30.0])
      ^"leads with [@Intensity.to_string] intensity"
    ]
    (Fire _)  "burns steady"
    (Water _) "flows"
    (Earth _) "builds"
    (Air _)   "thinks"
    |)
]

;; Wildcard
Option{Sign} [
  unwrapOrDefault(:@Self) Sign (|
    (Some) @Some.value
    (None) Aries
  |)
]

;; Large dispatch table — method on Planet with Sign param
;; @Sign infers type Sign (exists). No annotation needed.
Planet [
  dignity(:@Self @Sign) Dignity (|
    (Sun Leo)              Ruler
    (Moon Cancer)          Ruler
    (Venus Taurus)         Ruler
    (Venus Libra)          Ruler
    (Mars Aries)           Ruler
    (Jupiter Sagittarius)  Ruler
    (Saturn Capricorn)     Ruler
    (Sun Aries)            Exalted
    (Moon Taurus)          Exalted
    (Venus Pisces)         Exalted
    (Mars Capricorn)       Exalted
    (Jupiter Cancer)       Exalted
    (Saturn Libra)         Exalted
    (Sun Aquarius)         Detriment
    (Moon Capricorn)       Detriment
    (Sun Libra)            Fall
    (Moon Scorpio)         Fall
    (_ _)                  Peregrine
  |)
]


;; =============================================================
;; 14. COMMIT, BACKTRACK, and DESTRUCTURE ARMS
;; =============================================================
;;
;; The arm delimiter signals the mode:
;;
;; (pattern) result              Commit — match and return (Shen's ->)
;; [pattern] result              Backtrack — try, fail = next arm (Shen's <-)
;; {pattern | @Rest} result      Destructure — split sequence, bind tail
;;
;; All three mix freely in one matching body.
;; Backtrack: if the result expression fails, next arm.
;; Destructure: if the sequence doesn't match, next arm (backtracks).
;; The delimiter shape tells you instantly what the arm does.

;; Depth-first search with backtracking
State [
  depthFirst(:@Self @Goal Goal @Expand Expand) Bool (|
    [_]   @Self.checkGoal                              ;; try: is this the goal?
    [_]   @Self.expand.depthFirst(@Goal @Expand)       ;; try: go deeper
    [_]   @Self.siblings.depthFirst(@Goal @Expand)     ;; try: go sideways
    (_)   False                                        ;; commit: give up
  |)
]

;; Parser — all arms backtrack (try each parse, fall through on failure)
Tokens [
  item(:@Self) Option{Pair{Item Tokens}} (|
    [_] @Self.constDecl
    [_] @Self.mainDecl
    [_] @Self.domainDecl
    [_] @Self.structDecl
    [_] @Self.traitDecl
    [_] @Self.implBlock
  |)
]


;; =============================================================
;; 15. SEQUENCE DESTRUCTURING IN PATTERNS
;; =============================================================
;;
;; | inside a pattern separates matched head elements from tail binding.
;; Like Shen's [X Y Z | Xs] — match prefix, bind rest.
;;
;; THREE ARM TYPES in a matching body (| |):
;;
;; (pattern)              Commit arm    — Sol, match and return
;; [pattern]              Backtrack arm — Luna, try and fail = next
;; {pattern | @Rest}      Destructure arm — Saturn, split sequence
;;
;; Destructure arms use {} and ALWAYS contain | @Rest.
;; The {} delimiter tells the parser immediately: this is a
;; sequence split, not a value match. No lookahead needed.
;; Destructure arms backtrack on failure like [] arms.

;; Token stream parsing with destructuring — Shen-like grammar rules
Tokens [
  param(:@Self) Option{Pair{Param Tokens}} (|
    {Colon At Self  | @Rest}  Some(Pair(BorrowSelf @Rest))
    {Tilde At Self  | @Rest}  Some(Pair(MutBorrowSelf @Rest))
    {Colon At @Name | @Rest}  Some(Pair(Borrow(@Name) @Rest))
    {Tilde At @Name | @Rest}  Some(Pair(MutBorrow(@Name) @Rest))
    {At @Name @Type | @Rest}  Some(Pair(Named(@Name @Type) @Rest))
    {At @Name       | @Rest}  Some(Pair(Owned(@Name) @Rest))
  |)
]

;; List head/tail
Vec{Sign} [
  first(:@Self) Option{Sign} (|
    {@Head | _}  Some(@Head)
    (_)           None
  |)
]


;; =============================================================
;; 16. (removed — guards removed, conditions are patterns)
;; =============================================================
;;
;; Guards were {} after the result expression. Removed because:
;; - {} is now destructure arms — no double duty
;; - Conditions are expressed through pattern matching on values
;; - If everything is typed, the pattern IS the condition
;;
;; The F64.classify example becomes a matching method on a
;; wrapper domain, or uses backtracking arms that test conditions:
Positive (F64)
Negative (F64)
Zero ()
Classified (Positive Negative Zero)

F64 [
  classify(:@Self) Classified (|
    [_] Positive(@Self)    ;; backtrack: Positive.new validates > 0
    [_] Negative(@Self)    ;; backtrack: Negative.new validates < 0
    (_) Zero               ;; commit: must be zero
  |)
]


;; =============================================================
;; 17. RETURN — ^ mandatory in computed functions
;; =============================================================
;;
;; ^ is required in [] computed bodies. Not needed in (||) matching bodies.

;; Direct value
;; ^@Area

;; Expression
;; ^(@Addition.Left + @Addition.Right)

;; Inline eval
;; ^[@DeltaX + @DeltaY].sqrt


;; =============================================================
;; 18. MATCH INSIDE COMPUTED BODIES
;; =============================================================
;;
;; (||) inside [] for match-within-computation.
;; The match targets must be specified since they aren't the function params.

SignInput { Raw String }

SignInput [
  parse(:@Self) String [
    @Parsed Result{Sign ParseError}.new(@Self.Raw.parseSign)
    ^(| @Parsed
      (Ok)  @Ok.value.to_string
      (Err) @Err.message
    |)
  ]
]

;; Multi-step with mid-computation match
NatalChart [
  describeFull(:@Self) String [
    @Element Element.new(@Self.SunSign.element)
    @Modality Modality.new(@Self.SunSign.modality)
    ^(| @Element @Modality
      (Fire Cardinal) [
        @Intensity F64.new([@Self.SunSign.degree / 30.0])
        @IsStrong Bool.new([@Intensity > 0.5])
        ^(| @IsStrong
          (True)  "$(@Self.SunSign) leads with fierce initiative"
          (False) "$(@Self.SunSign) sparks quietly"
        |)
      ]
      (Fire _)  "$(@Self.SunSign) burns steady"
      (Water _) "$(@Self.SunSign) flows"
      (Earth _) "$(@Self.SunSign) builds"
      (Air _)   "$(@Self.SunSign) thinks"
    |)
  ]
]


;; =============================================================
;; 19. NO CLOSURES — type inference replaces anonymous functions
;; =============================================================
;;
;; No free functions also means no inline closures. A closure is
;; an anonymous free function — it contradicts the design.
;;
;; Instead: collection methods infer element bindings from the
;; collection's type parameter. Vec{Sign} → @Sign is available.
;; The accumulator binding is inferred from the initial value's type.
;; No variable naming, no closure syntax. The type system resolves
;; all accessor paths deterministically.
;;
;; ITERATION IS TRAITS:
;;
;; Collection methods with inferred element bindings replace closures.
;; Vec{Sign} → @Sign is the inferred element binding.
;;
;; Filter:  @Signs.filter(@Sign.Element == Fire)
;; Map:     @Signs.map(@Sign.Element)
;; Find:    @Signs.find(@Sign.Modality == Cardinal)
;; Each:    @Signs.each(StdOut @Sign.Element)
;; Count:   @Signs.count(@Sign.Element == Fire)
;;
;; Chain from named intermediates — each step has a name:
;; @FireSigns Vec{Sign}.new(@AllSigns.filter(@Sign.Element == Fire))
;; @FireModalities Vec{Modality}.new(@FireSigns.map(@Sign.Modality))
;;
;; FOLD TYPE CONSTRAINT:
;; The accumulator type MUST differ from the element type.
;; If the types match, there is a level of cognition not reflected
;; in the domains. Name what you're accumulating.
;;
;; The compiler transforms trait method arguments with inferred
;; bindings into Rust closures at codegen. No closure objects
;; exist at the aski level.


;; =============================================================
;; 20. ITERATION — traits and recursion, no loop syntax
;; =============================================================
;;
;; No loops. No while. No for. No break. No continue.
;; Iteration is expressed through:
;;   1. Collection traits: each, map, filter, find, fold, count
;;   2. Tail-recursive matching methods (Shen/Erlang approach)
;;
;; The collection type determines the element binding automatically.
;; "While condition" = tail recursion with a base case pattern.

;; Collection traits — inferred element binding
Vec{Sign} [
  firstCardinal(:@Self) Option{Sign} [
    ^@Self.find(@Sign.Modality == Cardinal)
  ]

  fireCount(:@Self) U32 [
    ^@Self.count(@Sign.Element == Fire)
  ]
]

;; Tail-recursive iteration — the Shen pattern
;; Pattern matching IS the loop condition.
;; The base case IS the termination test.
Batch { Remaining U32 }

Batch [
  processAll(:@Self) Batch (|
    (Remaining(0))  @Self                              ;; base case: done
    (_)             @Self.step.processAll              ;; recurse: keep going
  |)
]

;; "While x > 0" expressed as matching on struct field values.
;; The struct field pattern Remaining(0) matches the specific value.
;; No guard needed — the pattern IS the condition.


;; =============================================================
;; 21. TRAIT DECLARATION — solar envelope, lunar content
;; =============================================================
;;
;; traitName ([method signatures])
;; Trait names are camelCase — they are verbs (behavior).
;; Methods without [] = required.
;; Methods with [] = provided (default impl).

;; Simple trait
classify ([element(:@Self) Element])

;; Trait with default method
display ([
  ;; Required — no body
  name(:@Self) String

  ;; Provided — has default body
  display(:@Self) String [ ^@Self.name ]

  ;; Provided — uses other methods
  debug(:@Self) String [ ^"[$(@Self.name)]" ]
])


;; =============================================================
;; 22. SUPERTRAITS
;; =============================================================
;;
;; Supertrait list goes in the solar envelope before lunar methods.

;; Single supertrait
print (display [print(:@Self)])

;; Multiple supertraits
describe (display classify [describe(:@Self) String])

;; Composition only — no additional methods
render (display debug print [])


;; =============================================================
;; 23. TRAIT COMBINATION (& operator)
;; =============================================================
;;
;; & auto-creates a compound type.

;; In generic bounds — method on the compound type
{display&classify} [
  render(:@Self) String [
    ^@Self.display + " " + @Self.classify
  ]
]

;; Named explicitly via supertrait when desired
;; describe (display classify [])


;; =============================================================
;; 24. TRAIT IMPL — trait gathers its reflections
;; =============================================================
;;
;; traitName [Type [methods]]

classify [Point [element(:@Self) Element [
  @IsPositive Bool.new([@Self.Horizontal > 0.0])
  ^(| @IsPositive
    (True)  Fire
    (False) Water
  |)
]]]

;; Impl can override defaults or just implement required
display [Sign [name(:@Self) String [ ^@Self.to_string ]]]
;; display and debug use their defaults


;; =============================================================
;; 25. BLANKET IMPLS
;; =============================================================
;;
;; Trait impl where the type is a generic parameter.
;; {trait} in the type position.

;; Any type with display gets print
print [{display} [print(:@Self) [ StdOut @Self.display ]]]

;; Blanket with multiple bounds
describe [{display&classify} [describe(:@Self) String [
  ^@Self.display + " — " + @Self.element.to_string
]]]


;; =============================================================
;; 26. INHERENT IMPL
;; =============================================================
;;
;; Type [methods]

Point [
  translate(:@Self @DX F64 @DY F64) Self [
    ^Point(Horizontal([@Self.Horizontal + @DX]) Vertical([@Self.Vertical + @DY]))
  ]

  scale(:@Self @Factor F64) Self [
    ^Point(Horizontal([@Self.Horizontal * @Factor]) Vertical([@Self.Vertical * @Factor]))
  ]

  distance(:@Self @Other Point) F64 [
    @DeltaX F64.new([(@Self.Horizontal - @Other.Horizontal) * (@Self.Horizontal - @Other.Horizontal)])
    @DeltaY F64.new([(@Self.Vertical - @Other.Vertical) * (@Self.Vertical - @Other.Vertical)])
    ^[@DeltaX + @DeltaY].sqrt
  ]
]


;; =============================================================
;; 27. GENERICS — {} with trait name as type param
;; =============================================================
;;
;; No anonymous T. The trait name IS the type parameter.
;; trait in generic position = "any type implementing trait."
;; Trait names are camelCase — they are verbs.
;; No @ on trait bounds — @ is for instances only.

;; Simple — single bound (method on the generic)
{display} [
  transform(:@Self) String [ ^@Self.to_string ]
]

;; Multiple bounds via &
Vec{sort&display} [
  sortAndDisplay(:@Self) Vec{String} [
    ^@Self.sort.map(sort&display.to_string)
  ]
]

;; Multiple bounds use &. No separate where clause syntax.
;; {a} {a display} is replaced by {display&convert} etc.

;; Impl on generic instantiation
Vec{Sign} [
  fireCount(:@Self) U32 [
    ^@Self.filter(@Sign.Element == Fire).len
  ]

  cardinalSigns(:@Self) Vec{Sign} [
    ^@Self.filter(@Sign.Modality == Cardinal)
  ]
]


;; =============================================================
;; 28. LIFETIMES — type-based, not anonymous
;; =============================================================
;;
;; Borrows carry their origin through the type system.
;; The struct IS the lifetime scope. No 'a annotation in most code.

;; Struct that borrows — : marks the borrow
Excerpt {
  Text :String        ;; borrows a String — Excerpt can't outlive it
  Page U32
}

;; Interior reference (self-referential)
Message {
  Text String
  Body :Text          ;; borrows from own Text sub-type
}

;; In methods — :@Type already names the origin
;; The borrow's lifetime IS the input type
Pair{String} [
  longest(:@Self) String [
    @Longer Bool.new([@Self.First.len > @Self.Second.len])
    ^(| @Longer
      (True)  @Self.First
      (False) @Self.Second
    |)
  ]
]


;; =============================================================
;; 29. OWNERSHIP — move by default
;; =============================================================
;;
;; Actor model: send = transfer ownership.
;; Bare @Type in params = move (consume).
;; :@Type = shared borrow. ~@Type = mutable borrow.
;; Copy types (U32, F64, Bool, domains) — move is trivially a copy.

;; Move — method consumes the String
String [
  process(@Self) Bool [ ^@Self.len > 0 ]

  ;; Shared borrow — caller keeps the value
  inspect(:@Self) Bool [ ^@Self.len > 0 ]

  ;; Mutable borrow — exclusive access, caller keeps ownership
  appendSuffix(~@Self @Suffix String) [
    ~@Self.push(@Suffix)
  ]
]


;; =============================================================
;; 30. ERROR PROPAGATION
;; =============================================================
;;
;; ? postfix propagates errors. Result{T E} is the error type.

ChartInput { Raw String }

ChartInput [
  parse(:@Self) Result{NatalChart ParseError} [
    @Sign Sign.new(@Self.Raw.parseSign?)
    @Element Element.new(@Sign.element)
    ^Ok(NatalChart(SunSign(@Sign) MoonSign(Cancer) Rising(Libra)))
  ]
]

;; Chained ?
WorldSource { AgentSource String StoreSource String }

WorldSource [
  build(:@Self) Result{World Error} [
    @Agent Agent.new(@Self.AgentSource.parseAgent?)
    @Store Store.new(@Self.StoreSource.parseStore?)
    ^Ok(World(@Agent @Store))
  ]
]


;; =============================================================
;; 31. NEGATION
;; =============================================================
;;
;; ! is const prefix — not boolean negation.
;; Negation is a method.

;; Boolean negation
Element [
  isNotFire(:@Self) Bool [
    ^@Self.equals(Fire).not
  ]
]

;; Arithmetic negation
F64 [
  negate(:@Self) F64 [ ^@Self.neg ]
]


;; =============================================================
;; 32. BOUNDARY TEXT — strings exist only at I/O boundaries
;; =============================================================
;;
;; Interior data is ALWAYS domain ordinals. No String fields in domains.
;; The variant relation IS the string table:
;;   variant { domain_id, ordinal => name, wraps }
;; Swap the names in the DB → swap the display language. Zero code changes.
;;
;; String exists ONLY at boundaries:
;;   StdOut / StdErr / StdIn
;;   Contract messages (debug/panic context)
;;   Foreign function interface
;;
;; String CANNOT appear as:
;;   A struct-domain field type
;;   A method return type (use a domain instead)
;;
;; Interpolation: $Name renders ordinal→name lookup from variant table.
;; String literals: "text" — compile-time constant for boundary output.
;; Concatenation: + on boundary strings.

Main [
  @Element Element.new(Fire)
  StdOut @Element                    ;; renders "Fire" via variant lookup
  StdOut "element: $Element"         ;; $Element = ordinal→name lookup
]


;; =============================================================
;; 33. (removed — contracts are a bad type system)
;; =============================================================


;; =============================================================
;; 34. RANGE EXPRESSIONS
;; =============================================================

;; Exclusive: 0..12   (0 through 11)
;; Inclusive: 0..=11   (0 through 11)

;; Ranges are values — used with collection traits:
;; @Range Range{U32}.new(0..12)
;; @Range.each(StdOut @U32.to_string)


;; =============================================================
;; 35. YIELD / GENERATORS
;; =============================================================
;;
;; # yields and continues. ^ returns and terminates.
;; Generator functions return Iterator{T}.

;; Fibonacci as a method on U64 (generates from a starting pair)
;; ~@ declares a mutable binding — can be updated with ~@Name.set(value)
U64 [
  fibonacci(:@Self) Iterator{U64} [
    ~@Current U64.new(@Self)
    ~@Next U64.new(1)
    #@Current
    #@Next
    [|
      @Sum U64.new([@Current + @Next])
      #@Sum
      ~@Current.set(@Next)
      ~@Next.set(@Sum)
    ]
  ]
]


;; =============================================================
;; 36. ASSOCIATED TYPES IN TRAITS
;; =============================================================
;;
;; Bare PascalCase name in the trait body = associated type.

iterate ([Item
          next(~@Self) Option{Item}])

;; Impl provides the concrete type
iterate [SignIterator [Item Sign
                       next(~@Self) Option{Sign} [ ___ ]]]


;; =============================================================
;; 37. ASSOCIATED CONSTANTS IN TRAITS
;; =============================================================

bound ([!Max U32
        !Min U32
        clamp(:@Self) Self])

bound [Degree [!Max U32 {360}
                 !Min U32 {0}
                 clamp(:@Self) Self [ ___ ]]]


;; =============================================================
;; 38. TYPE ALIASES
;; =============================================================
;;
;; PascalCase name followed by another type (no delimiters) = alias.

ChartResult Result{NatalChart ChartError}
AppResult{T} Result{T AppError}
SignList Vec{Sign}
ElementMap Map{Element Vec{Sign}}


;; =============================================================
;; 39. REFINEMENT TYPES — TBD
;; =============================================================
;;
;; Constrained newtypes. Syntax TBD.
;; The constraint is a matching method on .new() that validates
;; at construction time — pattern matching IS the constraint.
;; If construction fails, .new() returns None (or panics).


;; =============================================================
;; 40. MODULE SYSTEM — file header
;; =============================================================
;;
;; Every file starts with a header using the three delimiters:
;;
;; () Sol — identity: what this file IS and exports
;; [] Luna — reflection: what this file uses (imports)
;; {} Saturn — structure: compilation constraints (optional)
;;
;; The header IS the module system. No Pub() scattered in code.
;; The reader sees the full public interface in the first lines.

;; === Example: parser module ===

(Parser domainDecl structDecl traitDecl item)
[Core (ParseState Token Tokens)
 Ast (Item Expr Pattern)]

;; Definitions follow — everything not in () is private.

;; === Example: chart module ===

(Chart NatalChart Element computeChart)
[Ephemeris (computePositions)
 Core (Sign Planet House)]

;; === Example: with Saturn constraints ===

(App main)
[Chart (NatalChart computeChart)
 Io (readInput writeOutput)]
{NoStd}

;; === Rules ===
;;
;; () is mandatory — every file declares its identity.
;;   First item = module name (PascalCase).
;;   Remaining items = exports (PascalCase nouns, camelCase verbs).
;;
;; [] is optional — only needed if file imports from other modules.
;;   Each entry: ModuleName (imported items).
;;   ModuleName (_) = import everything.
;;
;; {} is optional — structural constraints on compilation.
;;   Empty or absent = default configuration.
;;
;; Everything not listed in () is private to the file.
;; No Pub() — the header is the single source of visibility.


;; =============================================================
;; 41. COLLECTION OPERATIONS
;; =============================================================

;; -- Vec --

;; Construct — lunar []
;; Vec[Aries Taurus Gemini]

;; Read — solar ()
;; @Signs(0)

;; Write — saturnian {}
;; @Signs{0 Cancer}

;; Traits with inferred element binding — no closures
;; @Signs.map(@Sign.Element)
;; @Signs.filter(@Sign.Element == Fire)
;; @Signs.find(@Sign.Element == Water)
;; @Signs.count(@Sign.Element == Fire)
;; @Signs.each(StdOut @Sign.Element)

;; Push (mutates)
;; ~@Signs.push(Capricorn)

;; -- Map --

;; Construct — lunar []
;; Map[Aries Fire Taurus Earth Gemini Air]

;; Read — solar ()
;; @Elements(Aries)

;; Write — saturnian {}
;; @Elements{Cancer Water}

;; Membership
;; @Elements.contains(Aries)


;; =============================================================
;; 42. DELIMITER PROTOCOL — extensible delimiter behavior
;; =============================================================
;;
;; Every type can define what each delimiter does when applied to it.
;; The delimiter wrapping the definition matches the delimiter being defined.
;;
;; (Type (inputs) [body])   — defines what Type(...) does
;; [Type (inputs) [body]]   — defines what Type[...] does
;; {Type (inputs) [body]}   — defines what Type{...} does

;; Vec: construction, indexing, mutation
[Vec (T ...) [ ___ ]]              ;; Vec[...] constructs
(Vec (U32) [ ___ ])                ;; @Vec(...) reads at index
{Vec (U32 T) [ ___ ]}              ;; @Vec{...} writes at index

;; Map
[Map (K V ...) [ ___ ]]            ;; Map[k1 v1 k2 v2] constructs
(Map (K) [ ___ ])                  ;; @Map(...) reads
{Map (K V) [ ___ ]}                ;; @Map{...} writes

;; Option / Result
(Option (T) [ ___ ])               ;; Option(value) = Some
(Result (T) [ ___ ])               ;; Result(value) = Ok


;; =============================================================
;; 43. ENTRY POINT — Main
;; =============================================================

;; Main with lunar body — executes when program runs
Main [
  StdOut "hello aski"
]


;; =============================================================
;; 44. PARAM TYPE INFERENCE
;; =============================================================
;;
;; If a param name matches an existing type, the type is inferred.
;; No annotation needed. Only annotate when the name differs.
;;
;;   @Sign                  ;; infers type Sign (Sign exists)
;;   @Other Planet          ;; creates sub-type Other wrapping Planet
;;
;; Same rule as bindings — the name IS the type unless stated otherwise.

Planet [
  dignity(:@Self @Sign) Dignity (|
    (Sun Leo)     Ruler
    (_ _)         Peregrine
  |)

  ;; @Sign infers Sign. No "Sign" annotation needed.
  ;; @Other Planet creates sub-type Other wrapping Planet:
  distance(:@Self @Other) F64 [
    ___ ;; @Other is type Planet because we wrote @Other Planet
  ]
]


;; =============================================================
;; 45. BINARY ENCODING — aski↔bytes codec
;; =============================================================
;;
;; Every aski value has a binary form: ordinal bytes.
;; The codec converts bidirectionally between aski text and bytes.
;; World is the implicit schema — first byte identifies the domain.
;;
;; ENCODE: aski construction syntax → ordinal bytes
;;   "Placement(Body(Jupiter) Position(Sagittarius) HouseNum(Ninth))"
;;   → [world_ord, 5, 8, 8]
;;
;; DECODE: ordinal bytes → aski construction syntax
;;   [world_ord, 5, 8, 8]
;;   → "Placement(Body(Jupiter) Position(Sagittarius) HouseNum(Ninth))"
;;
;; ROUND-TRIP: encode(decode(bytes)) == bytes
;;
;; Self-describing: first byte = World variant ordinal.
;; No type parameter needed — the data carries its own identity.
;; rkyv is the serialization format. Unit-variant domains serialize
;; as a single discriminant byte = the ordinal.
;;
;; The CozoDB variant relation IS the string table:
;;   variant { domain_id, ordinal => name, wraps }
;; Swap the variant names in the DB → swap the display language.
;; Zero code changes for translation.


;; =============================================================
;; 46. COPY/CLONE — compiler-inferred
;; =============================================================
;;
;; No syntax. The codegen inspects all fields:
;;   All fields Copy → derive(Copy, Clone)
;;   All fields Clone → derive(Clone)
;;   Otherwise → neither
;; The programmer never writes Copy/Clone — the compiler decides.
;; This is safe: Rust rejects incorrect derives at compile time.
;;
;; Examples:
;;   Point { Horizontal F64 Vertical F64 }     → Copy, Clone (F64 is Copy)
;;   Element (Fire Earth Air)   → Copy, Clone (unit enum)
;;   Buffer { Data Vec{U8} }   → Clone only (Vec is not Copy)


;; =============================================================
;; 47. DROP — cleanup via trait impl
;; =============================================================
;;
;; drop is a core trait. Implement with existing trait syntax.
;; ~@Self = mutable borrow, matching Rust's &mut self in drop().

;; Core trait (in core, not user-written):
;; drop ([drop(~@Self)])

;; User impl:
;; drop [Connection [drop(~@Self) [
;;   @Self.close
;; ]]]
;;
;; Codegen: impl Drop for Connection { fn drop(&mut self) { self.close(); } }
;; Most domain types never need drop — compiler drops fields recursively.


;; =============================================================
;; 48. OPERATOR OVERLOADING — operator traits
;; =============================================================
;;
;; Operators desugar to trait method calls. Implement the trait,
;; the operator works. No new syntax — existing trait impl pattern.
;;
;; Operator → Trait mapping:
;;   +  → add     -  → sub     *  → mul     /  → div     %  → rem
;;   == → eq      != → eq (negated)
;;   <  → ord     >  → ord     <= → ord     >= → ord
;;   -  (unary) → neg          !  (unary) → not a thing (! is const prefix)

;; Core trait (in core):
;; add ([Output  add(:@Self @Rhs) Output])

;; User impl:
add [Point [Output Point
  add(:@Self @Rhs) Point [
    ^Point(Horizontal([@Self.Horizontal + @Rhs.Horizontal]) Vertical([@Self.Vertical + @Rhs.Vertical]))
  ]
]]

;; Now + works on Point:
;; @Sum Point.new([@PointA + @PointB])


;; =============================================================
;; 49. ARRAYS AND SLICES
;; =============================================================
;;
;; Arrays: fixed-size, stack-allocated. ! for const, {} for structure.
;; Slices: borrowed view of contiguous memory. : for borrow.
;;
;; !Array{N T} — const-sized array [T; N]
;; :Vec{T}     — borrowed slice &[T] (Vec borrows to slice automatically)

;; Array construction:
;; @Signs !Array{12 Sign}.new[Aries Taurus Gemini Cancer Leo Virgo
;;                            Libra Scorpio Sagittarius Capricorn Aquarius Pisces]

;; Slice in method params — :Vec{T} = &[T]:
;; Vec{Sign} [
;;   firstThree(:@Self) :Vec{Sign} [ ^@Self(0..3) ]
;; ]
;;
;; Codegen: :Vec{T} in param/return → &[T]. !Array{N T} → [T; N].


;; =============================================================
;; 50. NESTED PATTERN DESTRUCTURING
;; =============================================================
;;
;; Construction syntax and pattern syntax are the same form
;; read in opposite directions. Patterns nest to arbitrary depth.
;;
;; Construction: Point(Horizontal(3.0) Vertical(4.0))
;; Destructure:  (Horizontal(@Hv) Vertical(@Vv))

;; Nested domain destructuring:
;; Result{Result{Point Error} Error} [
;;   extractHorizontal(:@Self) Option{F64} (|
;;     (Ok (Ok (Horizontal(@Value) _)))    Some(@Value)
;;     (_ _)                      None
;;   |)
;; ]

;; Struct field value matching — the pattern IS the condition.
;; Matching on field values replaces guards:
Quadrant (NE NW SE SW Origin)

Point [
  quadrant(:@Self) Quadrant [
    ;; Compute intermediate values, then match
    @XPos Bool.new(@Self.isPositive)
    @YPos Bool.new(@Self.isPositive)
    ^(| @XPos @YPos
      (True True)   NE
      (False True)  NW
      (True False)  SE
      (False False) SW
    |)
  ]

  isPositive(:@Self) Bool (|
    ;; Domain-level: dispatches on the sign of the value
    ;; The condition becomes a method, the method becomes a pattern
    [_] True    ;; backtrack: try @Self > 0.0
    (_) False   ;; commit: otherwise false
  |)
]


;; =============================================================
;; 51. STRUCT UPDATE — .with auto-Protocol
;; =============================================================
;;
;; .with is auto-generated on every struct-domain (like .new).
;; Borrows @Self, returns new instance with specified fields changed.
;; Unspecified fields copied from @Self.

;; @Origin Point.new(Horizontal(0.0) Vertical(0.0))
;; @Shifted Point.new(@Origin.with(Horizontal(5.0)))     ;; Vertical stays 0.0
;;
;; Multiple field override:
;; @Updated NatalChart.new(@Chart.with(SunSign(Taurus) Rising(Scorpio)))
;; ;; MoonSign stays unchanged
;;
;; Codegen: Point { x: 5.0, ..origin }


;; =============================================================
;; 52. (removed — comprehensions replaced by collection traits)
;; =============================================================
;;
;; [||] comprehension syntax removed. Collection traits with
;; inferred element bindings replace it entirely:
;;
;;   @Signs.filter(@Sign.Element == Fire)     ;; was [| @Signs {@Sign.Element == Fire} |]
;;   @Signs.map(@Sign.Element)                ;; was [| @Signs @Sign.Element |]
;;   @Signs.filter(...).map(...)              ;; was [| @Signs expr {guard} |]
;;
;; [||] delimiter pair is now FREE for future use.


;; =============================================================
;; 53. | DISAMBIGUATION — or-pattern vs destructure tail
;; =============================================================
;;
;; | has two uses, distinguished by delimiter:
;;
;; 1. Inside () commit arms — or-pattern:
;;    (Fire | Air) result     bare names = OR
;;
;; 2. Inside {} destructure arms — tail binding:
;;    {Head | @Rest} result   always has @Rest after |
;;
;; These NEVER conflict because they use different delimiters.
;; () = commit with or-pattern. {} = destructure with tail.


;; =============================================================
;; 54. ASYNC BY DEFAULT
;; =============================================================
;;
;; Every function is async. No sync/async distinction in the surface
;; language. The compiler decides what to await. The programmer
;; writes sequential code, the runtime handles concurrency.
;; Core is the language, not a library.


;; =============================================================
;; 55. OPERATOR PRECEDENCE (highest to lowest)
;; =============================================================
;;
;;  1. .                  access
;;  2. ! : ~ @            prefix
;;  3. * / %              multiply
;;  4. + -                add
;;  5. .. ..=             range
;;  6. == != < > <= >=    comparison
;;  7. &&                 logical and
;;  8. ||                 logical or
;;  9. ?                  error propagation (postfix)
;; 10. ^ #               return/yield (lowest)


;; =============================================================
;; 56. ELIMINATED — no keywords for any of these
;; =============================================================
;;
;; fn          -> Type [name(params) Type [body]] or Type [name(params) Type (| arms |)]
;; free fn     -> does not exist — all behavior on types
;; let         -> @Name.new(expr) or @Name Type.new(expr)
;; let mut     -> ~@Name.new(expr), update with ~@Name.set(expr)
;; enum data   -> Variant(Type) or Variant { fields } inside domain ()
;; return      -> ^
;; if/else     -> (| |) match on Bool
;; match       -> (| |) or matching function form
;; for/while   -> collection traits (each, map, filter) + tail recursion
;; break       -> ^ return from recursive method (base case pattern)
;; continue    -> tail-call to self (recursive case pattern)
;; loop        -> tail-recursive matching method
;; const       -> ! prefix
;; pub         -> () file header lists exports; no Pub() needed
;; mod         -> file header: () self, [] imports, {} constraints
;; use         -> [] in file header lists imports
;; impl        -> traitName [Type [methods]]
;; where       -> & trait combination: {display&convert} (no separate where clause)
;; type        -> top-level PascalCase alias
;; mut         -> ~ prefix
;; async/await -> everything async by default
;; yield       -> # prefix
;; println     -> StdOut singleton
;; & for borrow -> : prefix (& is trait combination)
;; <> generics -> {} (freed for future use)
;; anonymous T -> trait name IS the type parameter (display not T)
;; ordinal _N  -> named struct inputs
;; if guard    -> removed — pattern matching IS the condition
;; backtrack   -> [] arm delimiter in (| |)
;; Box<T>      -> auto-boxed by compiler for recursive types
;; enum/struct -> both are domains — delimiter determines form
;; type annot  -> @Sign infers type Sign if it exists
;; String data -> ordinals in types, DB is the string table
;; serde/json  -> rkyv binary encoding, aski text is the human form
;; Display     -> codec decode: bytes → aski construction syntax
;; trait Foo   -> camelCase verb: traitName ([methods]) (section 21)
;; v0.9:
;; Copy/Clone  -> compiler-inferred from field types (section 46)
;; Drop        -> core trait drop, existing trait impl syntax (section 47)
;; operator +  -> impl add trait, operator desugars to method (section 48)
;; [T; N]      -> !Array{N T} (section 49)
;; &[T]        -> :Vec{T} in param/return position (section 49)
;; String      -> boundary-only, interior = ordinals (section 32)
;; destructure -> patterns = construction read backwards (section 50)
;; struct ..   -> .with auto-Protocol on all structs (section 51)
;; list comp   -> removed — collection traits: filter, map, each (section 19)
;; closure     -> does not exist — inferred element bindings replace closures
;; | ambiguity -> () = or-pattern, {} = destructure tail. Different delimiters (section 53)
;; {} arm      -> destructure arm: {pattern | @Rest} result (section 14, 15)
;; module      -> file header: () identity, [] imports, {} constraints (section 40)


;; =============================================================
;; COMPLETE SYMBOL TABLE (v0.9)
;; =============================================================
;;
;; DELIMITERS
;; ()     Sol       Domain, trait envelope, commit arms,
;;                  struct construction (auto), read/query on types,
;;                  file header: module identity + exports
;; []     Luna      Bodies, inline eval, collection construction,
;;                  backtrack arms, file header: imports
;; {}     Saturn    Struct body, generic params, const values,
;;                  mutation on types, destructure arms {pattern | @Rest},
;;                  file header: compilation constraints
;; (||)   Match     Matching function bodies, three arm types:
;;                  () commit, [] backtrack, {} destructure
;; [||]   FREE      Available (was comprehension)
;; {||}   FREE      Available
;; <>     FREE      Available
;;
;; SYMBOLS
;; .      access    Namespace, method, field, .new() construction
;; @      instance  Allocation marker and reference to allocated value
;; $      interp    Sugar for [@X.to_string] in strings
;; ^      return    Mandatory return prefix (computed functions only)
;; #      yield     Partial return (generator yield)
;; :      borrow    Immutable borrow / viewing
;; ~      mut       Mutable borrow
;; &      combine   Trait combination: display&classify
;; '      lifetime  Scope/duration parameter
;; ?      propagate Error propagation on Result (postfix)
;; ==     equals    Sugar for .equals
;; ..     range     Exclusive range
;; ..=    range     Inclusive range
;; ...    variadic  Zero or more (Protocol input shapes)
;; !      const     Compile-time fixity
;; >      greater   Comparison operator (no longer continue)
;; |      separator Or-pattern, sequence destructure
;; ;;     comment   Line comment
;; ___    stub      Placeholder for unwritten body
