;; grammar/field.aski — struct field forms

<field> {
  [@Name Colon <typeRef> | @Rest]   BorrowedField(@Name <typeRef>) @Rest
  [@Name <typeRef> | @Rest]         Field(@Name <typeRef>) @Rest
}

<fields> {
  [<field> <fields> | @Rest]   Cons(<field> <fields>) @Rest
  [| @Rest]                    Nil @Rest
}
